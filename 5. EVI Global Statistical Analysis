        "n_a": len(xa), "n_b": len(xb),
        "ks_stat": float(ks.statistic),
        "p_raw": float(ks.pvalue)
    })

ks_df = pd.DataFrame(ks_rows)

# ---- Holm / Dunn–Šidák / Bonferroni / none
def p_adjust(pvals, method="holm"):
    pvals = np.asarray(pvals, dtype=float)
    out = np.full_like(pvals, np.nan, dtype=float)
    idx = np.where(np.isfinite(pvals))[0]
    m = len(idx)
    if m == 0:
        return out

    p = pvals[idx]
    method = (method or "none").lower()

    if method == "none":
        out[idx] = p
        return out

    if method == "bonferroni":
        out[idx] = np.minimum(p * m, 1.0)
        return out

    if method in ["sidak", "dunn-sidak", "dunnsidak", "dunn–sidak"]:
        out[idx] = np.minimum(1.0 - (1.0 - p) ** m, 1.0)
        return out

    if method == "holm":
        # Holm step-down:
        # sort p ascending: p_(1)<=...<=p_(m)
        # adj p_(i) = max_{j<=i} min( (m-j+1)*p_(j), 1 )
        order = np.argsort(p)
        p_sorted = p[order]
        adj_sorted = np.empty_like(p_sorted)

        running_max = 0.0
        for i in range(m):
            factor = (m - i)
            val = min(p_sorted[i] * factor, 1.0)
            running_max = max(running_max, val)
            adj_sorted[i] = running_max

        # place back
        adj = np.empty_like(p)
        adj[order] = adj_sorted
        out[idx] = adj
        return out

    raise ValueError(f"Unknown method: {method}")

ks_df["p_adj"] = p_adjust(ks_df["p_raw"].values, method=P_ADJUST)

